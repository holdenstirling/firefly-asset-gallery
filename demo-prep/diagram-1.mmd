        BB["GitHub PRs<br/><span style='font-size:12px;opacity:0.7'>Bugbot review</span>"]:::surface
    end

    REPO[("Your codebase")]:::repo

    ENG --> IDE
    ENG --> SLACK
    ENG --> WEB
    ENG --> BB

    IDE --> REPO
    SLACK --> REPO
    WEB --> REPO
    BB --> REPO

    classDef person fill:#1e1e2e,stroke:#cba6f7,color:#cdd6f4,stroke-width:2px;
