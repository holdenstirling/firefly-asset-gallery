flowchart LR
    ENG(("Engineer")):::person

    subgraph SURFACES["Cursor — one engineer, four surfaces"]
        direction TB
        IDE["Cursor IDE<br/><span style='font-size:12px;opacity:0.7'>Ask · Plan · Build</span>"]:::surface
        SLACK["Slack<br/><span style='font-size:12px;opacity:0.7'>@Cursor mention</span>"]:::surface
